# Copy to .env for WSL2 Ubuntu or cloud deployment.
# Do not commit .env. It is ignored by git.

ODM_DATABASE_PATH=data/option-data-current.sqlite3
ODM_WEB_HOST=127.0.0.1
ODM_WEB_PORT=8765
ODM_API_HOST=127.0.0.1
ODM_API_PORT=8770

# Optional: force the Linux/WSL Fernet key location.
# Default: ~/.config/option-data-manager/secret.key
# ODM_SECRET_KEY_FILE=~/.config/option-data-manager/secret.key

# Prefer transient environment variables for cloud jobs.
# For local WSL WebUI, you may also save credentials through Settings.
TQSDK_ACCOUNT=
TQSDK_PASSWORD=

# Set to 1 only when you intentionally want the Settings page to test a live TQSDK connection.
ODM_ENABLE_TQSDK_CONNECTION_TEST=0
